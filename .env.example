# ═══════════════════════════════════════════════════════
# ytclfr — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to source control.
# ═══════════════════════════════════════════════════════

# -- Database ------------------------------------------
DATABASE_URL=postgresql://postgres.your_project:your_password_here@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_POOL_SIZE=5

# -- Cache / Queue -------------------------------------
REDIS_URL=redis://localhost:6379/0

# -- Temporary Storage ---------------------------------
TEMP_MEDIA_PATH=/tmp/ytclfr_media
TEMP_MEDIA_MAX_AGE_SECONDS=3600

# Path to Netscape-format cookies file exported from
# Firefox after logging into YouTube.
# Required for downloading most YouTube videos.
# Export by closing Firefox, visiting youtube.com,
# then: yt-dlp --cookies-from-browser firefox
#              --cookies cookies.txt
#              "https://youtu.be/jNQXAC9IVRw"
# Cookies expire ~2 weeks. Re-export when downloads
# start failing with bot detection error.
# NEVER commit cookies.txt to git.
YTDLP_COOKIES_FILE=/absolute/path/to/cookies.txt

# -- LLM / AI -----------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
LLM_REQUEST_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# -- ASR -----------------------------------------------
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# -- OCR -----------------------------------------------
TESSERACT_CMD_PATH=tesseract
OCR_FRAME_SAMPLE_RATE=1

# -- Router ------------------------------------------------
ROUTER_FRAME_SAMPLE_COUNT=5

# -- Authentication ------------------------------------
JWT_SECRET_KEY=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# -- Service -------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
WORKER_CONCURRENCY=2
CELERY_TASK_TIME_LIMIT=1800

# -- General -------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development


# -- AWS S3 -------------------------------------------
AWS_ACCESS_KEY_ID=key-here
AWS_SECRET_ACCESS_KEY=secret-key-here
AWS_REGION=region-here
S3_BUCKET_NAME=bucket-name-here
